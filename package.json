{
  "name": "printing-management-system",
  "version": "1.0.0",
  "description": "نظام إدارة المطبعة - تطبيق سطح مكتب",
  "author": "Printing Management System",
  "private": true,
  "main": "electron-starter.js",
  "scripts": {
    "dev": "next dev",
    "dev-electron": "next dev -p 8000",
    "build": "next build && node scripts/postbuild.js",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "electron": "electron .",
    "rebuild-native": "electron-rebuild -f -w better-sqlite3",
    "dist": "npm run build && npm run rebuild-native && electron-builder"
  },
  "build": {
    "appId": "com.printingmanagement.app",
    "productName": "نظام إدارة المطبعة",
    "files": [
      "electron-starter.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "standalone"
      }
    ],
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "dotenv": "17.3.1",
    "drizzle-orm": "0.45.2",
    "html2pdf.js": "^0.14.0",
    "next": "16.2.6",
    "pg": "8.20.0",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@tailwindcss/postcss": "4.1.17",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "22.19.15",
    "@types/pg": "8.18.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "drizzle-kit": "0.31.10",
    "electron": "^42.5.0",
    "electron-builder": "^25.1.8",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "postcss": "8.5.8",
    "tailwindcss": "4.1.17",
    "typescript": "5.9.3"
  }
}
